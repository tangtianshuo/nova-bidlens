  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "Node",
    "strict": true,
    "declaration": false,
    "outDir": "dist/cjs",
    "rootDir": "src",
    "skipLibCheck": true,
    "esModuleInterop": true
  },
