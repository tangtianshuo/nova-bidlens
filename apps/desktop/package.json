{
  "name": "@bidlens/desktop",
  "private": true,
  "version": "0.1.0",
  "description": "BidLens - AI文档智能比对桌面应用",
  "author": "BidLens Team",
  "main": "dist/main/index.js",
  "scripts": {
    "native:electron": "electron-rebuild -f -w better-sqlite3",
    "native:node": "npm rebuild better-sqlite3",
    "dev": "pnpm native:electron && tsc -p tsconfig.main.json && concurrently -k \"vite\" \"wait-on http://localhost:5373 && electron .\"",
    "dev:renderer": "vite",
    "build": "tsc -p tsconfig.json && tsc -p tsconfig.main.json && vite build && pnpm check:fixtures",
    "build:win": "cargo build --release --manifest-path ../../bidlens-engine/Cargo.toml && pnpm build && electron-builder --win",
    "build:mac": "cargo build --release --manifest-path ../../bidlens-engine/Cargo.toml && pnpm build && electron-builder --mac",
    "build:linux": "cargo build --release --manifest-path ../../bidlens-engine/Cargo.toml && pnpm build && electron-builder --linux",
    "build:all": "tsc -p tsconfig.json && tsc -p tsconfig.main.json && vite build && electron-builder --win --mac --linux",
    "test": "pnpm native:node && vitest run",
    "test:e2e": "tsc -p tsconfig.main.json && playwright test",
    "check:fixtures": "tsx scripts/check-fixtures.ts",
    "lint": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@bidlens/shared": "workspace:*",
    "@radix-ui/react-alert-dialog": "^1.1.20",
    "@radix-ui/react-checkbox": "^1.3.8",
    "@radix-ui/react-collapsible": "^1.1.17",
    "@radix-ui/react-dialog": "^1.1.19",
    "@radix-ui/react-dropdown-menu": "^2.1.20",
    "@radix-ui/react-popover": "^1.1.20",
    "@radix-ui/react-progress": "^1.1.12",
    "@radix-ui/react-radio-group": "^1.4.4",
    "@radix-ui/react-scroll-area": "^1.2.14",
    "@radix-ui/react-select": "^2.3.3",
    "@radix-ui/react-separator": "^1.1.11",
    "@radix-ui/react-slot": "^1.3.0",
    "@radix-ui/react-tabs": "^1.1.17",
    "@radix-ui/react-tooltip": "^1.2.12",
    "@tailwindcss/postcss": "^4.3.3",
    "@tailwindcss/vite": "^4.3.3",
    "@tanstack/react-query": "^5.64.2",
    "@tanstack/react-virtual": "^3.14.6",
    "better-sqlite3": "^12.11.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "diff": "^8.0.2",
    "electron-log": "5.4.4",
    "fast-xml-parser": "^4.5.1",
    "jszip": "^3.10.1",
    "lucide-react": "^1.25.0",
    "postcss": "^8.5.19",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-resizable-panels": "^4.12.2",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.3",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.2.0",
    "@playwright/test": "^1.49.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.1.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^33.2.1",
    "electron-builder": "^26.15.3",
    "jsdom": "^25.0.1",
    "tsx": "^4.19.0",
    "vite": "^6.0.7",
    "vitest": "^2.1.8"
  }
}
